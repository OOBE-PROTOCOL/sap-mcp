{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.oobeprotocol.sap.mcp/sap-mcp",
  "title": "SAP MCP Server | OOBE Protocol",
  "description": "Solana-native MCP gateway for SAP tools, DeFi, SNS identity, x402/pay.sh, and agent operations.",
  "version": "0.9.12",
  "websiteUrl": "https://mcp.sap.oobeprotocol.ai/",
  "repository": {
    "url": "https://github.com/OOBE-PROTOCOL/sap-mcp",
    "source": "github",
    "id": "1283972695"
  },
  "icons": [
    {
      "src": "https://mcp.sap.oobeprotocol.ai/favicon.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.sap.oobeprotocol.ai/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@oobe-protocol-labs/sap-mcp-server",
      "version": "0.9.12",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "--yes"
        },
        {
          "type": "positional",
          "value": "--package"
        },
        {
          "type": "positional",
          "value": "@oobe-protocol-labs/sap-mcp-server@0.9.12"
        },
        {
          "type": "positional",
          "value": "sap-mcp-server"
        }
      ],
      "environmentVariables": [
        {
          "name": "SAP_MCP_ALLOW_ENV_CONFIG_OVERRIDE",
          "description": "Keep SAP MCP pointed at the active profile manager instead of stale client env overrides.",
          "format": "boolean",
          "value": "false"
        },
        {
          "name": "SAP_LOG_LEVEL",
          "description": "Runtime log level for local SAP MCP stdio sessions.",
          "format": "string",
          "default": "info"
        }
      ]
    }
  ]
}
