{
  "name": "@oobe-protocol-labs/sap-mcp-server",
  "version": "0.1.0",
  "description": "Official MCP gateway for OOBE Protocol SAP — AI agents can interact with SAP identity, registry, reputation, tools, memory, payments, settlement, and proof-of-execution on Solana",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sap-mcp-server": "./dist/cli.js",
    "sap-mcp-config": "./dist/config-cli.js",
    "sap-mcp-wizard": "./dist/tui/config-wizard.js",
    "sap-signing-proxy": "./dist/signer/signing-proxy.js",
    "sap-mcp-remote": "./dist/remote/server.js",
    "sap-mcp-facilitator": "./dist/payments/oobe-facilitator-server.js",
    "sap-mcp-pay-sh-spec": "./dist/payments/pay-sh-spec.js"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example",
    "config.example.json",
    "config.secure-example.json",
    "config.schema.json",
    "ecosystem.config.example.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && tsc && tsc -p tsconfig.tui.json",
    "build:core": "tsc",
    "build:tui": "tsc -p tsconfig.tui.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "config": "tsx src/config-cli.ts",
    "tui:config": "tsx src/tui/config-wizard.tsx",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src/",
    "test": "vitest",
    "verify:release": "pnpm run typecheck && pnpm run lint && pnpm test -- --run && pnpm run build && npm pack --dry-run --cache ./.npm-cache",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "sap",
    "synapse",
    "oobe",
    "agent",
    "ai",
    "blockchain"
  ],
  "author": "OOBE Protocol Labs",
  "license": "MIT",
  "dependencies": {
    "@bonfida/spl-name-service": "3.0.9",
    "@coral-xyz/anchor": "^0.30.1",
    "@langchain/core": "^0.3.80",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@oobe-protocol-labs/synapse-client-sdk": "^2.0.6",
    "@oobe-protocol-labs/synapse-sap-sdk": "^0.21.0",
    "@solana/kit": "^5.5.1",
    "@solana/sysvars": "^5.5.1",
    "@solana/web3.js": "^1.95.0",
    "@x402/core": "^2.17.0",
    "@x402/express": "^2.17.0",
    "@x402/svm": "^2.17.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "cli-spinners": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ioredis": "^5.4.0",
    "js-sha256": "^0.11.0",
    "jsonwebtoken": "^9.0.0",
    "react": "^19.2.7",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bn.js": "^5.2.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@bentoguard/sdk": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@bentoguard/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "overrides": {
    "langsmith": "^0.6.0",
    "uuid": "^11.1.1"
  },
  "pnpm": {
    "overrides": {
      "langsmith": "^0.6.0",
      "uuid": "^11.1.1"
    }
  }
}
