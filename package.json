{
  "name": "@oobe-protocol-labs/sap-mcp-server",
  "version": "0.9.15",
  "mcpName": "ai.oobeprotocol.sap.mcp/sap-mcp",
  "description": "Official MCP gateway for OOBE Protocol SAP — AI agents can interact with SAP identity, registry, reputation, tools, memory, payments, settlement, and proof-of-execution on Solana",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sap-mcp-server": "dist/bin/sap-mcp-server.js",
    "sap-mcp-config": "dist/config-cli.js",
    "sap-mcp-wizard": "dist/tui/config-wizard.js",
    "sap-signing-proxy": "dist/signer/signing-proxy.js",
    "sap-mcp-remote": "dist/bin/sap-mcp-remote.js",
    "sap-mcp-facilitator": "dist/payments/oobe-facilitator-server.js",
    "sap-mcp-pay-sh-spec": "dist/payments/pay-sh-spec.js",
    "sap-mcp-x402-paid-call": "dist/payments/x402-paid-call.js"
  },
  "files": [
    "dist",
    "assets",
    "skills",
    "docs",
    "USER_DOCS",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "server.json",
    "smithery.config.schema.json",
    ".env.example",
    "config.example.json",
    "config.secure-example.json",
    "config.schema.json",
    "ecosystem.config.example.cjs",
    "vendor/bigint-buffer"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && tsc && tsc -p tsconfig.tui.json",
    "build:core": "tsc",
    "build:tui": "tsc -p tsconfig.tui.json",
    "desktop:renderer": "vite --config apps/desktop/vite.config.ts",
    "desktop:renderer:build": "vite build --config apps/desktop/vite.config.ts",
    "desktop:build": "pnpm run build && pnpm run desktop:renderer:build && electron-builder --config apps/desktop/electron-builder.cjs --publish never",
    "desktop:verify-artifact": "node scripts/verify-desktop-artifact.mjs",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "config": "tsx src/config-cli.ts",
    "tui:config": "tsx src/tui/config-wizard.tsx",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src/",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:release": "pnpm run typecheck && pnpm run lint && pnpm run test:run && pnpm run build && npm pack --dry-run --cache ./.npm-cache",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "solana",
    "sap",
    "synapse",
    "oobe",
    "agent",
    "ai",
    "blockchain"
  ],
  "author": "OOBE Protocol Labs",
  "license": "MIT",
  "homepage": "https://mcp.sap.oobeprotocol.ai/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OOBE-PROTOCOL/sap-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/OOBE-PROTOCOL/sap-mcp/issues"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "3.0.9",
    "@coral-xyz/anchor": "^0.30.1",
    "@langchain/core": "^0.3.80",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@oobe-protocol-labs/synapse-client-sdk": "^2.0.6",
    "@oobe-protocol-labs/synapse-sap-sdk": "^1.0.2",
    "@solana/kit": "^5.5.1",
    "@solana/sysvars": "^5.5.1",
    "@solana/web3.js": "^1.95.0",
    "@x402/core": "^2.17.0",
    "@x402/express": "^2.17.0",
    "@x402/svm": "^2.17.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "cli-spinners": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ioredis": "^5.4.0",
    "js-sha256": "^0.11.0",
    "jsonwebtoken": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tweetnacl": "^1.0.3",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron/notarize": "2.5.0",
    "@eslint/js": "^9.39.4",
    "@types/bn.js": "^5.2.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vite": "8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@bentoguard/sdk": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@bentoguard/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0",
  "overrides": {
    "bigint-buffer": "file:vendor/bigint-buffer",
    "esbuild": "^0.28.1",
    "langsmith": "^0.6.0",
    "uuid": "^11.1.1",
    "vite": "8.1.0",
    "ws": "^8.21.0"
  }
}
