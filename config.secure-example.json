{
  "$schema": "https://raw.githubusercontent.com/oobe-protocol-labs/sap-mcp-server/main/config.schema.json",
  
  "_comment": "SAP MCP Server - Secure JSON Configuration",
  "_docs": "https://github.com/oobe-protocol-labs/sap-mcp-server/blob/main/docs/CONFIGURATION.md",
  "_version": "1.0.0",
  
  "mode": "readonly",
  "rpcUrl": "https://api.mainnet-beta.solana.com",
  "rpcUrlDevnet": "https://api.devnet.solana.com",
  "rpcUrlTestnet": "https://api.testnet.solana.com",
  "programId": "SAPpUhsWLJG1FfkGRcXagEDMrMsWGjbky7AyhGpFETZ",
  "commitment": "confirmed",
  
  "maxRetries": 3,
  "retryDelayMs": 1000,
  
  "walletPath": "~/.config/mcp-sap/keypairs/dev-wallet-keypair.json",
  "walletEncrypted": false,
  "walletPassphraseEnv": "WALLET_PASSPHRASE",
  
  "externalSignerUrl": "https://signer.example.com/api/v1/sign",
  "externalSignerTimeoutMs": 30000,
  
  "enableHttp": false,
  "httpPort": 8787,
  "httpHost": "127.0.0.1",
  "httpCorsOrigins": [
    "https://app.example.com",
    "https://admin.example.com"
  ],
  
  "maxTxValueSol": 10,
  "requireApprovalAboveSol": 1,
  "dailyLimitSol": 100,
  "allowedTools": "all",
  
  "logLevel": "info",
  "logFormat": "pretty",
  "logFile": "~/.local/share/mcp-sap/logs/sap-mcp.log",
  
  "enableMetrics": false,
  "metricsPort": 9090,
  
  "enableCache": true,
  "cacheTtlSeconds": 300,
  "enableRateLimit": true,
  "rateLimitPerMinute": 60,

  "monetization": {
    "enabled": false,
    "provider": "x402",
    "payTo": "YOUR_SOLANA_USDC_RECIPIENT",
    "network": "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp",
    "facilitatorUrl": "https://x402.oobeprotocol.ai/facilitator",
    "maxTimeoutSeconds": 120,
    "payShCheckoutUrl": "https://pay.sh/checkout/YOUR_CHECKOUT_ID",
    "prices": {
      "readPremiumUsd": 0.001,
      "builderUsd": 0.008,
      "valueFixedUsd": 0.09,
      "heavyValueUsd": 0.15,
      "valueBps": 0,
      "minUsd": 0.001,
      "maxUsd": 100
    }
  },
  
  "$security": {
    "_comment": "Fields that require approval before changing",
    "requireApprovalFor": [
      "mode",
      "walletPath",
      "externalSignerUrl",
      "maxTxValueSol",
      "requireApprovalAboveSol",
      "dailyLimitSol"
    ],
    "approvalTimeout": 300,
    "maxChangesPerDay": 10,
    "requireMultiSig": false,
    "multiSigThreshold": 2,
    "multiSigApprovers": []
  },
  
  "$audit": {
    "_comment": "Audit trail configuration",
    "enabled": true,
    "logPath": "~/.local/share/mcp-sap/audit.jsonl",
    "retentionDays": 90,
    "submitToOracle": false,
    "oracleEndpoint": ""
  },
  
  "$meta": {
    "version": "1.0.0",
    "createdAt": "2026-06-23T10:00:00.000Z",
    "updatedAt": "2026-06-23T10:00:00.000Z",
